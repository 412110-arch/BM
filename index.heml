<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BMI 健康計算機</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap');
        body {
            font-family: 'Noto+Sans+TC', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 1.5rem;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>

<div class="glass-card w-full max-w-md p-8">
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-800">BMI 計算機</h1>
        <p class="text-gray-500 mt-2">輸入身高與體重，掌握您的健康狀態</p>
    </div>

    <div class="space-y-6">
        <!-- 身高輸入 -->
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">身高 (cm)</label>
            <input type="number" id="height" placeholder="例如：175" 
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all">
        </div>

        <!-- 體重輸入 -->
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">體重 (kg)</label>
            <input type="number" id="weight" placeholder="例如：65" 
                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all">
        </div>

        <!-- 計算按鈕 -->
        <button onclick="calculateBMI()" 
            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl shadow-lg transform active:scale-95 transition-all">
            開始計算
        </button>

        <!-- 結果顯示區 -->
        <div id="result-container" class="hidden mt-8 p-6 rounded-2xl text-center transition-all duration-500">
            <div class="text-sm font-medium text-gray-600 mb-1">您的 BMI 指數</div>
            <div id="bmi-value" class="text-5xl font-extrabold mb-3">22.5</div>
            <div id="bmi-status" class="text-xl font-bold mb-4">體重正常</div>
            
            <div class="h-2 w-full bg-gray-200 rounded-full overflow-hidden mb-4">
                <div id="status-bar" class="h-full transition-all duration-1000" style="width: 0%"></div>
            </div>
            
            <p id="bmi-suggestion" class="text-sm text-gray-600 leading-relaxed"></p>
        </div>
    </div>

    <!-- 底部說明 -->
    <div class="mt-8 pt-6 border-t border-gray-100">
        <div class="grid grid-cols-2 gap-2 text-xs text-gray-400">
            <div>過輕: < 18.5</div>
            <div>正常: 18.5 - 24</div>
            <div>過重: 24 - 27</div>
            <div>肥胖: > 27</div>
        </div>
    </div>
</div>

<script>
    function calculateBMI() {
        const heightInput = document.getElementById('height');
        const weightInput = document.getElementById('weight');
        const resultContainer = document.getElementById('result-container');
        const bmiValueDisplay = document.getElementById('bmi-value');
        const bmiStatusDisplay = document.getElementById('bmi-status');
        const bmiSuggestion = document.getElementById('bmi-suggestion');
        const statusBar = document.getElementById('status-bar');

        const h = parseFloat(heightInput.value) / 100; // 轉換為公尺
        const w = parseFloat(weightInput.value);

        if (!h || !w || h <= 0 || w <= 0) {
            alert('請輸入正確的身高與體重數值');
            return;
        }

        const bmi = (w / (h * h)).toFixed(1);
        
        // 顯示結果容器
        resultContainer.classList.remove('hidden');
        bmiValueDisplay.innerText = bmi;

        let status = '';
        let colorClass = '';
        let suggestion = '';
        let barWidth = '';

        if (bmi < 18.5) {
            status = '體重過輕';
            colorClass = 'bg-blue-100 text-blue-800';
            barColor = 'bg-blue-500';
            suggestion = '建議多攝取營養，並配合適度運動來增加肌肉量。';
            barWidth = '25%';
        } else if (bmi >= 18.5 && bmi < 24) {
            status = '體重正常';
            colorClass = 'bg-green-100 text-green-800';
            barColor = 'bg-green-500';
            suggestion = '恭喜您！請繼續維持均衡飲食與規律運動的生活習慣。';
            barWidth = '50%';
        } else if (bmi >= 24 && bmi < 27) {
            status = '體重過重';
            colorClass = 'bg-yellow-100 text-yellow-800';
            barColor = 'bg-yellow-500';
            suggestion = '要注意飲食囉！調整攝取量並增加運動頻率。';
            barWidth = '75%';
        } else {
            status = '肥胖';
            colorClass = 'bg-red-100 text-red-800';
            barColor = 'bg-red-500';
            suggestion = '建議諮詢營養師或醫師，規劃減重計畫以降低健康風險。';
            barWidth = '100%';
        }

        // 更新 UI
        resultContainer.className = `mt-8 p-6 rounded-2xl text-center transition-all duration-500 ${colorClass}`;
        bmiStatusDisplay.innerText = status;
        bmiSuggestion.innerText = suggestion;
        
        // 重置並重新觸發進度條動畫
        statusBar.className = `h-full transition-all duration-1000 ${barColor}`;
        setTimeout(() => {
            statusBar.style.width = barWidth;
        }, 10);
    }
</script>

</body>
</html>
